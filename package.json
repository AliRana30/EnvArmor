    "@upstash/redis": "^1.35.7",
    "framer-motion": "^11.15.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^1.8.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.8.1",
    "resend": "^4.0.1"
  },
  "devDependencies": {
